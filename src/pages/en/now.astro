---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
---

<PageLayout title="Now" description="What I'm doing right now.">
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white">
        Now
      </div>
      <article class="animate space-y-4">
        <p>
          Right now I'm picking up Sailing Notes again as a personal log about learning, coding, micro-SaaS, quant trading, and loose ideas.
        </p>
        <p>
          The goal is to write small notes, document progress, and leave a trace of the process — without turning this into a content machine.
        </p>
      </article>
    </div>
  </Container>
</PageLayout>
