---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/Link.astro";
import { SITE, METADATA, SOCIALS } from "@consts";
import { translations } from "@lib/i18n";
import { formatDate } from "@lib/utils";

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft && post.data.lang === 'en');

const findings = (await getCollection("findings"))
  .filter(finding => !finding.data.draft && finding.data.lang === 'en');

const recent = [...blog, ...findings]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const t = translations.en;
---

<PageLayout title={METADATA.home.en.TITLE} description={METADATA.home.en.DESCRIPTION}>
  <Container>
    <h1 class="animate font-semibold text-black dark:text-white">
      {t.home.greeting}
    </h1>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate">
            {t.home.intro1}
          </p>
          <p class="animate">
            {t.home.intro2}
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <h2 class="font-semibold text-black dark:text-white">
          {t.home.latestNotes}
        </h5>
        <ul class="flex flex-col">
          {recent.map(item => {
            const typeLabel = item.collection === 'blog' ? t.home.typeBlog : t.home.typeFinding;
            const href = `/en/${item.collection}/${item.slug}`;
            return (
              <li>
                <a href={href} class="group flex flex-wrap items-baseline gap-x-3 gap-y-0.5 py-2.5 border-b border-black/5 dark:border-white/5 hover:text-black dark:hover:text-white transition-colors duration-200">
                  <span class="text-sm text-black/40 dark:text-white/40 tabular-nums shrink-0">
                    {formatDate(item.data.date)}
                  </span>
                  <span class="text-xs uppercase tracking-wide text-black/30 dark:text-white/30 shrink-0">
                    {typeLabel}
                  </span>
                  <span class="group-hover:underline underline-offset-2">
                    {item.data.title}
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>

      <section class="animate space-y-4">
        <h2 class="font-semibold text-black dark:text-white">
          {t.home.letsConnect}
        </h5>
        <article>
          <p>
            {t.home.connectText}
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {"/"}
            </li>
          ))}
          <li class="line-clamp-1">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
